<input id="phone"/>

<h2>Sản phẩm muốn mua <span class="required">*</span></h2>

<div id="product-list"></div>
<div id="product-blocks"></div>

<div class="total">
Tổng tiền: <span id="total">0</span> VNĐ
</div>

<div class="qr-section">
<h2>QR Thanh toán</h2>
<p class="note">
  Vui lòng chuyển đúng số tiền kèm note "Mã NV" hoặc "Số điện thoại" (ví dụ INNO2001 hoặc 0343567889)
  và upload bill chuyển khoản bên dưới.
</p>
<img
  src="https://raw.githubusercontent.com/haiaunt195-prog/INNO-order/main/QR%20code-inno%20noi%20bo.png"
  class="qr-image"
/>
</div>

<h2>Upload bill chuyển khoản <span class="required">*</span></h2>
<input type="file" id="paymentProof" accept="image/*"/>

<button onclick="submitOrder()">Gửi đơn hàng</button>

</div>

<script>
// Kiểm tra hạn đăng ký
const deadline = new Date("2026-05-31T23:59:59+07:00");
if (new Date() > deadline) {
  document.querySelector(".container").innerHTML = `
    <div style="text-align:center;padding:60px 20px;">
      <img src="https://raw.githubusercontent.com/haiaunt195-prog/INNO-order/main/logo-inno-black.png" style="width:160px;margin-bottom:32px;"/>
      <div style="font-size:64px;margin-bottom:16px;">🔒</div>
      <h2 style="font-size:28px;font-weight:700;margin-bottom:12px;">Chương trình đã kết thúc</h2>
      <p style="font-size:16px;color:#666;line-height:1.7;">
        Ưu đãi nội bộ đã kết thúc vào 23:59:59 ngày 31/05/2026.<br/>
        Cảm ơn bạn đã quan tâm!
      </p>
    </div>
  `;
}
const ADDRESS_MAP = {
  "OPPO_Công ty Cổ Phần Kỹ Thuật & Khoa Học Vĩnh Khang": "Tầng 16, tòa nhà UOA, 6 Tân Trào, P. Tân Mỹ, HCM",
  "DJI_Công Ty TNHH Kỹ Thuật Tầm Nhìn Toàn Cầu": "Tầng 5, tòa nhà UOA, 6 Tân Trào, P. Tân Mỹ",
  "[HCM] O-TECH_Công Ty TNHH Thiết Bị Thông Minh O-TECH HCM": "Tầng 7, toà nhà UOA, 6 Tân Trào, P. Tân Mỹ, HCM",
  "[HN] O-TECH_Công Ty TNHH Thiết Bị Thông Minh O-TECH Hà Nội": "195 Khuất Duy Tiến, phường Đại Mổ, Hà Nội",
  "EV Power_Công Ty TNHH EV Power": "Tầng 16- UOA số 6 Tân Trào, Tân Mỹ, TpHCM",
  "NAM VIỆT_Công ty Cổ Phần Nam Việt Land": "Tầng 6, Tòa nhà UOA, số 6 Tân Trào, P. Tân Mỹ",
  "Service": "27 Nguyễn Trung Trực, Bến Thành, Hồ Chí Minh",
  "Call center": "Lô M, Chung cư Carillon - Số 1, Đường Trần Văn Danh, P.Tân Bình, TPHCM",
  "Kho HCM": "Số 2639 Quốc Lộ 1, KP3, P. Đông Hưng Thuận, TP.HCM",
  "Kho Hà Nội": "Kho PLS, Lô số 3 Cụm CN Lai Xá, Kim Chung, Hoài Đức, Hà Nội",
  "Oway Sài Gòn": "816 Sư Vạn Hạnh, P. Hoà Hưng, TP. HCM",
  "Oway Biên Hoà": "108 Xa Lộ Hà Nội, P. Tam Hiệp, Đồng Nai",
  "Oway Quy Nhơn": "Tổ 9, Khu vực 8, P. Quy Nhơn Bắc, Gia Lai",
  "Oway Đà Nẵng": "548-554 Nguyễn Hữu Thọ, P. Cẩm Lệ, Đà Nẵng",
  "INNO_Công Ty TNHH Thiết Bị Thông Minh INNO": "Số 12 đường số 5, KCD Sadeco, Phường Tân Hưng"
};

function updateAddress() {
  const company = document.getElementById("company").value;
  const addressInput = document.getElementById("address");
  addressInput.value = ADDRESS_MAP[company] || "";
}

const CLOUDINARY_CLOUD_NAME = "ddpsybbri";
const CLOUDINARY_UPLOAD_PRESET = "inno_upload";
const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbz0HeVbyzDNWWMI4FnbjV--LSq3G-KqH6Og02gqzHS6cXSCqy2oHlr4458qsdElr4M0mg/exec";

const products = [
  { code:"INNO-B001", name:"Quạt InnoFans Handheld", price:200000, colors:["Bạc","Đen","Vàng"] },
  { code:"INNO-B015", name:"Quạt Innoyo Fan Air", price:250000, colors:["Hồng","Trắng","Tím"] },
  { code:"INNO-B003", name:"Quạt InnoFans Ice", price:210000, colors:["Trắng","Tím","Hồng"] },
  { code:"INNO-B009", name:"Quạt InnoFans Ice Pro", price:270000, colors:["Xám","Vàng","Đen"] },
  { code:"INNO-B008", name:"Tăm nước Innoyo Water Flosser", price:470000, colors:["Hồng","Xanh"] },
  { code:"INNO-B007", name:"Tăm nước mini InnoCare Water Flosser Pocket", price:500000, colors:["Trắng"] },
  { code:"INNO-C001", name:"Máy rửa xe cầm tay InnoCare Cordless Washer Gun", price:599000, colors:["Default"] },
  { code:"P-PG-005", name:"Tay cầm chụp ảnh", price:600000, colors:["Default"] },
  { code:"P-PG-012", name:"Đèn trợ sáng điện thoại PGYTECH", price:270000, colors:["Default"] },
  { code:"INNO-B012", name:"Máy Sấy Tóc Innoyo Plasma Lite", price:660000, colors:["Hồng","Trắng"] },
  { code:"INNO-B014", name:"Máy Sấy Tóc Innoyo Plasma", price:900000, colors:["Tím","Trắng"] },
  { code:"INNO-B013", name:"Máy sấy tóc INNOYO Plasma AI", price:1380000, colors:["Gold"] }
];

const productList = document.getElementById("product-list");
const productBlocks = document.getElementById("product-blocks");

products.forEach((p, index) => {

  const checkbox = document.createElement("div");
  checkbox.className = "product-checkbox";
  checkbox.id = `card-${index}`;
  checkbox.onclick = (e) => {
  if (e.target.type === "checkbox") return;
  const cb = document.getElementById(`check-${index}`);
  cb.checked = !cb.checked;
  toggleProduct(index);
};
  checkbox.innerHTML = `
    <div style="display:flex;align-items:center;gap:14px;width:100%;">
      <input type="checkbox" id="check-${index}" onchange="toggleProduct(${index})"/>
      <label for="check-${index}" style="margin:0;cursor:pointer;line-height:1.5;">
        <b>${p.code}</b> - ${p.name}
        <span style="color:#666;font-weight:400;">(${p.price.toLocaleString()}đ)</span>
      </label>
    </div>
  `;
  productList.appendChild(checkbox);

  const block = document.createElement("div");
  block.className = "product-block";
  block.id = `product-${index}`;

  let colorsHTML = "";
  p.colors.forEach(color => {
    colorsHTML += `
      <div>
        <label>${color}</label>
        <input type="number" min="0" placeholder="Nhập số lượng" value="" disabled
          id="${p.code}_${color}" oninput="calculateTotal()"/>
      </div>
    `;
  });

  block.innerHTML = `
    <div class="product-block-header">
      <div class="product-block-code">${p.code}</div>
      <div class="product-block-name">${p.name}</div>
      <div class="product-block-price">${p.price.toLocaleString()}đ</div>
    </div>
    <div class="color-grid">${colorsHTML}</div>
  `;
  productBlocks.appendChild(block);
});

function toggleProduct(index) {
  const checked = document.getElementById(`check-${index}`).checked;
  const block = document.getElementById(`product-${index}`);
  const card = document.getElementById(`card-${index}`);

  block.style.display = checked ? "block" : "none";
  checked ? card.classList.add("selected") : card.classList.remove("selected");

  const product = products[index];
  product.colors.forEach(color => {
    const input = document.getElementById(`${product.code}_${color}`);
    input.disabled = !checked;
    if (!checked) input.value = "";
  });

  calculateTotal();
}

function calculateTotal() {
  let total = 0;
  products.forEach(p => {
    p.colors.forEach(color => {
      const input = document.getElementById(`${p.code}_${color}`);
      if (input) {
        const qty = parseInt(input.value || 0);
        total += qty * p.price;
      }
    });
  });
  document.getElementById("total").innerText = total.toLocaleString();
}

async function compressImage(file) {
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.readAsDataURL(file);
    reader.onload = (event) => {
      const img = new Image();
      img.src = event.target.result;
      img.onload = () => {
        const canvas = document.createElement("canvas");
        const MAX_WIDTH = 1000;
        const scale = MAX_WIDTH / img.width;
        canvas.width = MAX_WIDTH;
        canvas.height = img.height * scale;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        canvas.toBlob((blob) => { resolve(blob); }, "image/jpeg", 0.7);
      };
    };
  });
}

async function uploadToCloudinary(file) {
  const compressedFile = await compressImage(file);
  const formData = new FormData();
  formData.append("file", compressedFile, "bill.jpg");
  formData.append("upload_preset", CLOUDINARY_UPLOAD_PRESET);
  const response = await fetch(
    `https://api.cloudinary.com/v1_1/${CLOUDINARY_CLOUD_NAME}/image/upload`,
    { method: "POST", body: formData }
  );
  const data = await response.json();
  return data.secure_url;
}

async function submitOrder() {
  const button = document.querySelector("button");
  const fullName = document.getElementById("name").value.trim();
  const company = document.getElementById("company").value.trim();
  const address = document.getElementById("address").value.trim();
  const email = document.getElementById("email").value.trim();
  const employeeCode = document.getElementById("employeeCode").value.trim();
  const phone = document.getElementById("phone").value.trim();

  if (!fullName || !company || !address || !email || !employeeCode || !phone) {
    alert("Vui lòng nhập đầy đủ thông tin");
    return;
  }

  const items = [];
  try {
    products.forEach((p, index) => {
      const checked = document.getElementById(`check-${index}`).checked;
      if (!checked) return;
      let hasQty = false;
      p.colors.forEach(color => {
        const input = document.getElementById(`${p.code}_${color}`);
        const qty = parseInt(input.value || 0);
        if (qty > 0) {
          hasQty = true;
          items.push({ product: `${p.code} - ${p.name}`, color, qty, price: p.price, total: qty * p.price });
        }
      });
      if (!hasQty) throw new Error(`Vui lòng nhập số lượng cho ${p.name}`);
    });
  } catch(e) {
    alert(e.message);
    return;
  }

  if (items.length === 0) {
    alert("Vui lòng chọn sản phẩm");
    return;
  }

  const file = document.getElementById("paymentProof").files[0];
  if (!file) {
    alert("Vui lòng upload bill");
    return;
  }

  try {
    button.disabled = true;
    button.innerText = "Đang upload bill...";
    const paymentImage = await uploadToCloudinary(file);
    button.innerText = "Đang gửi đơn hàng...";
    const payload = {
      fullName, company, address, email, employeeCode, phone,
      total: document.getElementById("total").innerText.replace(/,/g, ""),
      paymentImage,
      items
    };
    await fetch(GOOGLE_SCRIPT_URL, { method: "POST", body: JSON.stringify(payload) });
    button.innerText = "Đặt hàng thành công";
    alert("Đặt hàng thành công");
    location.reload();
  } catch(error) {
    console.error(error);
    alert(error.message || "Có lỗi xảy ra");
    button.disabled = false;
    button.innerText = "Gửi đơn hàng";
  }
}

</script>

</body>
</html>


