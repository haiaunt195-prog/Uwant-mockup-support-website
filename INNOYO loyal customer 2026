<option value="Kho HCM">Kho HCM</option>
<option value="Kho Hà Nội">Kho Hà Nội</option>
<option value="Oway Sài Gòn">Oway Sài Gòn</option>
<option value="Oway Biên Hoà">Oway Biên Hoà</option>
<option value="Oway Quy Nhơn">Oway Quy Nhơn</option>
<option value="Oway Đà Nẵng">Oway Đà Nẵng</option>
<option value="INNO_Công Ty TNHH Thiết Bị Thông Minh INNO">INNO – Công Ty TNHH Thiết Bị Thông Minh INNO</option>
</select>

<label>Địa chỉ nhận hàng <span class="required">*</span></label>
<input id="address" readonly placeholder="Tự động điền khi chọn công ty"/>

